{
  "name": "my-bible-log",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "expo start",
    "start:dev": "EXPO_PUBLIC_API_BASE_URL=http://localhost:8080 expo start",
    "start:staging": "EXPO_PUBLIC_API_BASE_URL=https://staging.example.com expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "EXPO_PUBLIC_API_BASE_URL=http://localhost:8080 expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "eas:build:android:dev": "eas build --platform android --profile development",
    "clean": "rm -rf node_modules .expo .expo-shared .turbo dist build coverage android ios"
  },
  "dependencies": {
    "@expo/metro-runtime": "~56.0.15",
    "@expo/vector-icons": "^15.0.3",
    "@mybiblelog/shared": "file:../shared",
