    "@types/jest": "^29.5.14",
    "@types/react": "^19.2.13",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~56.0.4",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.0",
    "react-test-renderer": "^19.2.3",
    "typescript": "~6.0.3"
  }
