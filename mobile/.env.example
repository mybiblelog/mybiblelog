## Public client-side config (embedded into bundle)
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

## Google Sign-In (native). The web client ID is the audience of the id_token
## the app sends to the API; it MUST be listed in the API's GOOGLE_ALLOWED_CLIENT_IDS.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
## Optional — only required for native iOS sign-in.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
