{
  "name": "mybiblelog",
  "version": "1.0.0",
  "description": "A web app for tracking personal Bible reading, built with Nuxt.",
  "author": {
    "name": "Aaron Smith",
    "url": "https://github.com/AaronSmithX"
  },
  "private": true,
  "workspaces": [
    "api",
    "nuxt",
    "shared"
  ],
  "engines": {
    "node": "24.2.0"
  },
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:nuxt",
    "dev:api": "npm run -w api dev:ts",
    "dev:nuxt": "npm run -w nuxt dev",
    "start": "npm-run-all --parallel start:api start:nuxt",
    "start:api": "npm run -w api start",
    "start:nuxt": "npm run -w nuxt start",
    "build": "npm run build -w api && npm run build -w nuxt",
    "heroku-prebuild": "npm install && npm install --include=dev -w shared && npm install -w nuxt && npm install -w api",
    "heroku-postbuild": "npm run build",
    "clean": "rm -rf node_modules && npm run clean -w api && npm run clean -w nuxt && npm run clean -w shared",
    "lint": "eslint --ext .js,.ts,.vue --ignore-path .gitignore .",
    "lint:fix": "eslint --ext .js,.ts,.vue --ignore-path .gitignore . --fix",
    "test": "jest",
    "test:serial": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:api": "npm run -w api test",
    "test:e2e": "playwright test e2e",
    "test:e2e:ui": "playwright test e2e --ui",
    "script:seed": "npm run -w api script:seed",
    "script:backup": "npm run -w api script:backup",
    "script:delete-test-users": "npm run -w api script:delete-test-users",
    "script:delete-stranded-data": "npm run -w api script:delete-stranded-data",
    "script:migrate": "npm run -w api script:migrate",
    "screenshots": "npx tsx scripts/take-screenshots.ts"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 10000,
    "projects": [
      {
        "displayName": "api-tests",
        "testMatch": [
          "<rootDir>/api/test/**/*.test.js"
        ],
        "testEnvironment": "node"
      },
      {
        "displayName": "shared-tests",
        "preset": "ts-jest",
        "testMatch": [
          "<rootDir>/shared/**/*.test.ts"
        ],
        "testEnvironment": "node",
        "roots": [
          "<rootDir>/shared"
        ],
        "transform": {
          "^.+\\.ts$": "ts-jest"
        },
        "moduleFileExtensions": [
          "ts",
          "js",
          "json",
          "node"
        ]
      }
    ]
  },
  "dependencies": {
    "cross-env": "^7.0.3",
    "npm-run-all": "^4.1.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@types/node": "^22.14.1",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "openai": "^4.54.0",
    "sharp": "^0.34.5",
    "ts-jest": "^29.2.0"
  },
  "overrides": {
    "mongoose-unique-validator": {
      "mongoose": "^9.1.6"
    }
  }
}
