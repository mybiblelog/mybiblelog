{
  "name": "mybiblelog",
  "version": "1.0.0",
  "description": "A web app for tracking personal Bible reading, built with Nuxt.",
  "author": {
    "name": "Aaron Smith",
    "url": "https://github.com/AaronSmithX"
  },
  "private": true,
  "workspaces": [
    "api",
    "web",
    "shared"
  ],
  "engines": {
    "node": "24.18.0"
  },
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:web",
    "dev:api": "npm run -w api dev:ts",
    "dev:web": "npm run -w web dev",
    "start": "npm-run-all --parallel start:api start:web",
    "start:api": "npm run -w api start",
    "start:web": "npm run -w web start",
    "build": "npm run build -w api && npm run build -w web",
    "build:web": "npm run -w web build",
    "heroku-prebuild": "npm install --include=dev && npm install --include=dev -w shared && npm install -w web && npm install -w api",
    "heroku-postbuild": "npm run build",
    "clean": "npm run clean:root && npm run clean -w api && npm run clean -w web && npm run clean -w shared",
    "clean:root": "rm -rf node_modules playwright-report test-results",
    "lint": "eslint --ext .js,.ts,.vue --ignore-path .gitignore .",
    "lint:fix": "eslint --ext .js,.ts,.vue --ignore-path .gitignore . --fix",
    "test": "npm run test:shared && npm run test:web",
    "test:shared": "npm run -w shared test",
    "test:web": "npm run -w web test",
    "test:api": "npm run -w api test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "script:seed": "npm run -w api script:seed",
    "script:backup": "npm run -w api script:backup",
    "script:delete-test-users": "npm run -w api script:delete-test-users",
    "script:delete-stranded-data": "npm run -w api script:delete-stranded-data",
    "script:migrate": "npm run -w api script:migrate",
    "screenshots:web": "npx tsx scripts/take-web-screenshots.ts",
    "screenshots:mobile": "npx tsx scripts/take-mobile-screenshots.ts"
  },
  "dependencies": {
    "cross-env": "^7.0.3",
    "npm-run-all": "^4.1.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@types/node": "^22.14.1",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "openai": "^4.54.0",
    "sharp": "^0.34.5"
  }
}