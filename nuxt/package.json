{
  "name": "mybiblelog-client",
  "version": "1.0.0",
  "private": true,
  "description": "My Bible Log Nuxt.js Web App",
  "license": "MIT",
  "author": "Aaron Smith",
  "type": "commonjs",
  "scripts": {
    "i18n:export-crowdin": "tsx ./scripts/i18n/export-crowdin-locales.ts",
    "i18n:import-crowdin": "tsx ./scripts/i18n/import-crowdin-locales.ts",
    "i18n:verify-keys": "tsx ./scripts/i18n/verify-i18n-keys.ts",
    "dev": "cross-env NODE_ENV=development nuxt2 dev",
    "start": "cross-env NODE_ENV=production nuxt2 start",
    "build": "nuxt2 build",
    "clean": "rm -rf node_modules .nuxt",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint --ext .ts,.js,.vue .",
    "lint:fix": "eslint --ext .ts,.js,.vue . --fix"
  },
  "dependencies": {
    "@mybiblelog/shared": "*",
    "@nuxt/bridge": "^3.6.1",
    "@nuxt/content": "^1.14.0",
    "@nuxtjs/i18n": "^7.3.1",
    "@nuxtjs/proxy": "^2.1.0",
    "@nuxtjs/pwa": "^3.3.4",
    "@nuxtjs/redirect-module": "^0.3.1",
    "@nuxtjs/robots": "^2.5.0",
    "cookie": "^0.4.2",
    "csv-parse": "^4.16.3",
    "csv-stringify": "^5.6.5",
    "dayjs": "^1.10.4",
    "dotenv": "^8.2.0",
    "nuxi": "^3.31.2",
    "nuxt": "^2.18.1",
    "pinia": "^2.3.1",
    "redirect-ssl": "^3.0.0",
    "vue-gtag": "^1.16.1"
  },
  "devDependencies": {
    "@nuxt/types": "^2.18.1",
    "@nuxt/typescript-build": "^3.0.2",
    "@nuxtjs/eslint-config-typescript": "^12.1.0",
    "@nuxtjs/eslint-module": "^3.1.0",
    "css-loader": "^5.2.7",
    "postcss": "^8.5.10",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vitest": "^3.2.6"
  }
}
