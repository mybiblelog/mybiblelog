{
  "name": "@mybiblelog/shared",
  "version": "1.0.0",
  "private": true,
  "description": "Shared utilities for My Bible Log",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf node_modules dist",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint --ext .ts .",
    "lint:fix": "eslint --ext .ts . --fix",
    "prepare": "npm run build"
  },
  "keywords": [
    "bible",
    "utilities",
    "shared"
  ],
  "author": "Aaron Smith",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.9.1",
    "vitest": "^3.2.6"
  },
  "peerDependencies": {
    "dayjs": "^1.10.4"
  },
  "dependencies": {
    "typescript": "^5.9.3"
  }
}
